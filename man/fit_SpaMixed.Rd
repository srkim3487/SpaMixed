  phy_obj = physeq_example,
  exposure = "PM2.5",
  covariates = c("age", "gender"),
  region_var = "zip_code",
  region_adj = adj_mat,
  micro_adj = adj_micro,
  scale_vars = c("PM2.5", "age"),
  factor_vars = c("gender"),
  lfdr_thres = 0.2
)

